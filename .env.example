# ─────────────────────────────────────────────────────────────────────────────
# .env.example — Watt Distributors (feature/payroll-system, block 16)
#
# Copy to .env.local for dev or to .env.production-like for preview / prod
# in Vercel. Do NOT commit the actual filled-in file.
#
# Variables fall into three groups:
#   1. Always required (NextAuth, Supabase, business TZ).
#   2. Push / email — required when those channels are used.
#   3. Block-15 payroll worker token — required when a scheduled cron
#      calls /api/payroll/notifications/process.
# ─────────────────────────────────────────────────────────────────────────────

# ── 1. Core ──────────────────────────────────────────────────────────────────
# NextAuth session signing secret. Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=

# Public-facing base URL (used in emails + push deep-links).
NEXT_PUBLIC_APP_URL=https://your-vercel-preview.vercel.app

# Business timezone — used for week calculations, payfile cutoffs, etc.
NEXT_PUBLIC_BUSINESS_TZ=America/Chicago
PROJECT_TIMEZONE=America/Chicago

# Supabase project — service-role bypasses RLS and is used server-side.
# IMPORTANT: when pasting from Supabase, trim trailing whitespace — a stray
# \n in the ANON_KEY breaks all Realtime WebSockets (logged in memory).
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Google Maps JS API key for the assignments / geofence views.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Legacy /shift panel — set to "1" to keep the old standalone shift page
# visible in the nav. Leave unset/empty to hide.
NEXT_PUBLIC_LEGACY_SHIFT_PANEL=

# ── 2. Web Push (VAPID) ─────────────────────────────────────────────────────
# Generate once with: npx web-push generate-vapid-keys
# Both public and private MUST be set or push is disabled (warning at boot).
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CONTACT_EMAIL=mailto:admin@wattdistributors.com

# ── 2b. Email (temp passwords / resets) ─────────────────────────────────────
# Either Resend (preferred) OR SMTP. Resend wins when both are set.
RESEND_API_KEY=
RESEND_FROM=

SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# ── 3. Payroll queue worker ─────────────────────────────────────────────────
# Shared secret a cron job sends in the `x-worker-token` header when calling
# /api/payroll/notifications/process. Leave empty in dev — admin/CEO sessions
# can also invoke the worker for manual draining.
PAYROLL_QUEUE_WORKER_TOKEN=
